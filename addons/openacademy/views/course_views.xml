<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_course_tree" model="ir.ui.view">
        <field name="name">course.tree</field>
        <field name="model">openacademy.course</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="responsible_id"/>
            </tree>
        </field>
    </record>

    <record id="view_course_form" model="ir.ui.view">
        <field name="name">course.form</field>
        <field name="model">openacademy.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="responsible_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">openacademy.course</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_openacademy_main" name="Open Academy" sequence="10"/>
    <menuitem id="menu_course" name="Courses" parent="menu_openacademy_main" action="action_course" sequence="20"/>
</odoo>
