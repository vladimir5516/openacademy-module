<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Liste des sessions -->
        <record id="view_openacademy_session_tree" model="ir.ui.view">
            <field name="name">openacademy.session.tree</field>
            <field name="model">openacademy.session</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="course_id"/>
                    <field name="instructor_id"/>
                    <field name="start_date"/>
                    <field name="duration"/>
                    <field name="seats"/>
                    <field name="taken_seats" widget="progressbar"/>
                </tree>
            </field>
        </record>

        <!-- Formulaire des sessions -->
        <record id="view_openacademy_session_form" model="ir.ui.view">
            <field name="name">openacademy.session.form</field>
            <field name="model">openacademy.session</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="course_id"/>
                            <field name="instructor_id"/>
                            <field name="start_date"/>
                            <field name="duration"/>
                            <field name="seats"/>
                            <field name="taken_seats" widget="progressbar"/>
                        </group>
                        <group string="Participants">
                            <field name="attendee_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action pour ouvrir les sessions -->
        <record id="action_openacademy_session" model="ir.actions.act_window">
            <field name="name">Sessions</field>
            <field name="res_model">openacademy.session</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Ajouter le menu Sessions -->
        <menuitem id="menu_openacademy_session" 
                  name="Sessions" 
                  parent="openacademy.menu_openacademy_main"
                  action="action_openacademy_session"
                  sequence="20"/>
    </data>
</odoo>
